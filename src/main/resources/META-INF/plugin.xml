<idea-plugin>
    <id>com.firebasebuilduploader.android</id>
    <name>Firebase Co-Pilot Build Uploader</name>
    <vendor email="hardil.undavia@gmail.com">Hardil Undavia</vendor>
    <version>1.0.0</version>

    <description><![CDATA[
        <b>Firebase Co-Pilot: Build Uploader</b> — Smart Firebase Distribution for Android Developers<br/><br/>
        Streamline your Android build and distribution workflow directly from Android Studio:<br/>
        <ul>
            <li>Auto-detects project flavors (UAT, Prod, etc.)</li>
            <li>Select different build type with flavor support</li>
            <li>Upload APK directly to Firebase App Distribution</li>
            <li>Add release notes before every deployment</li>
            <li>Service account JSON authentication — no manual token setup</li>
        </ul>
    ]]></description>

    <change-notes><![CDATA[
        <b>1.0.0</b> — Initial release with full Firebase App Distribution support.
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.android</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="Firebase Co-Pilot: Build Uploader"
            anchor="right"
            factoryClass="com.firebasebuilduploader.ui.FirebaseCoPilotToolWindowFactory"
            icon="/icons/buildpilot_13.svg"
        />

        <applicationService
            serviceInterface="com.firebasebuilduploader.services.FirebaseCoPilotSettingsService"
            serviceImplementation="com.firebasebuilduploader.services.FirebaseCoPilotSettingsService"
        />

        <projectService
            serviceInterface="com.firebasebuilduploader.services.GradleFlavorDetectorService"
            serviceImplementation="com.firebasebuilduploader.services.GradleFlavorDetectorService"
        />

        <projectService
            serviceInterface="com.firebasebuilduploader.services.BuildService"
            serviceImplementation="com.firebasebuilduploader.services.BuildService"
        />

        <projectService
            serviceInterface="com.firebasebuilduploader.services.FirebaseDistributionService"
            serviceImplementation="com.firebasebuilduploader.services.FirebaseDistributionService"
        />
    </extensions>

    <actions>
        <action
            id="FirebaseCoPilot.OpenPanel"
            class="com.firebasebuilduploader.actions.OpenFirebaseCoPilotAction"
            text="Firebase Co-Pilot: Build Uploader — Deploy to Firebase"
            description="Open Firebase Co-Pilot: Build Uploader panel to build and distribute your app"
            icon="/icons/buildpilot_13.svg"
        >
            <add-to-group group-id="BuildMenu" anchor="last"/>
            <add-to-group group-id="MainToolBar" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift F"/>
        </action>
    </actions>
</idea-plugin>
